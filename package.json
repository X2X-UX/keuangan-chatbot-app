{
  "name": "keuangan-chatbot-app",
  "version": "1.0.0",
  "description": "Personal finance dashboard with transaction tracking, cashflow insights, receipt capture, and Telegram-assisted financial chat.",
  "main": "src/server/index.js",
  "scripts": {
    "preflight": "node scripts/preflight.js",
    "build:tailwind": "tailwindcss -c tailwind.config.js -i src/client/styles.tailwind.css -o src/client/.generated/tailwind.css --minify",
    "sync:public": "node scripts/sync-public.js",
    "test:light": "node scripts/test-modules.js",
    "test:routes": "node scripts/test-routes.js",
    "test:telegram": "node scripts/test-telegram-flow.js",
    "verify": "node scripts/verify.js",
    "prestart": "npm run sync:public",
    "predev": "npm run sync:public",
    "start": "node src/server/index.js",
    "dev": "node src/server/index.js",
    "telegram:webhook": "node register-telegram-webhook.js"
  },
  "keywords": [
    "finance",
    "dashboard",
    "pwa",
    "telegram",
    "chatbot",
    "sqlite",
    "nodejs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/X2X-UX/keuangan-chatbot-app.git"
  },
  "bugs": {
    "url": "https://github.com/X2X-UX/keuangan-chatbot-app/issues"
  },
  "homepage": "https://github.com/X2X-UX/keuangan-chatbot-app#readme",
  "engines": {
    "node": ">=22.18.0"
  },
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
