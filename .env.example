PORT=3000
NODE_ENV=development

# Chat assistant is local-only. The variables below are optional and used only for receipt analysis integrations.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OCR_SPACE_API_KEY=

APP_BASE_URL=https://your-app.onrender.com
ALLOWED_ORIGINS=
SESSION_COOKIE_SAME_SITE=Lax
BODY_LIMIT_BYTES=5000000
STATIC_CACHE_MAX_AGE_SECONDS=300
SLOW_REQUEST_THRESHOLD_MS=1000
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_AUTO_SET_WEBHOOK=true
TELEGRAM_RECEIPT_DRAFT_TTL_MS=900000
RATE_LIMIT_API_MAX=240
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AUTH_WINDOW_MS=600000
RATE_LIMIT_CHAT_MAX=50
RATE_LIMIT_CHAT_WINDOW_MS=60000
RATE_LIMIT_TELEGRAM_WEBHOOK_MAX=1200
RATE_LIMIT_TELEGRAM_WEBHOOK_WINDOW_MS=60000
RATE_LIMIT_TRANSACTION_WRITE_MAX=60
RATE_LIMIT_TRANSACTION_WRITE_WINDOW_MS=60000
ARUNIKA_DATA_DIR=
ARUNIKA_DB_FILE=
